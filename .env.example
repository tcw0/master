# =============================================================================
# DDD Pipeline Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# OpenRouter API Key (for cloud models)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# LangSmith Tracing (optional — enables automatic observability)
# -----------------------------------------------------------------------------
# When enabled, all LangChain chain invocations are automatically traced.
# Sign up at https://smith.langchain.com/ to get an API key.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=ddd-pipeline
